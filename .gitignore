## A streamlined .gitignore for modern .NET projects
## including temporary files, build results, and
## files generated by popular .NET tools. If you are
## developing with Visual Studio, the VS .gitignore
## https://github.com/github/gitignore/blob/main/VisualStudio.gitignore
## has more thorough IDE-specific entries.
##
## Get latest from https://github.com/github/gitignore/blob/main/Dotnet.gitignore

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# NuGet Packages
*.nupkg
# NuGet Symbol Packages
*.snupkg

# dotenv environment variables file
.env

# Others
~$*
*~
CodeCoverage/

# MSBuild Binary and Structured Log
*.binlog

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

# IDEs
.vs/
.vscode/
.idea/
*.user
*.suo
*.userprefs
*.userosscache
*.sln.docstates
*.swp

# OS
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# AMiracle.Echo runtime artifacts (local dev DBs, blob stores, smoke-test outputs)
echo.db
echo.db-*
smoketest.db
smoketest.db-*
echo-blobs/
smoketest-blobs/
src/AMiracle.Echo.Host/echo.db
src/AMiracle.Echo.Host/echo.db-*
src/AMiracle.Echo.Host/smoketest.db
src/AMiracle.Echo.Host/smoketest.db-*
src/AMiracle.Echo.Host/echo-blobs/
src/AMiracle.Echo.Host/smoketest-blobs/

# Local secret overrides (don't commit admin tokens, connection strings, etc.)
appsettings.local.json
appsettings.*.local.json
src/**/appsettings.local.json
src/**/appsettings.*.local.json

# User secrets are stored under %APPDATA% so they don't need ignoring, but in case anyone exports them:
*.secrets.json

# Logs
*.log
/tmp/
