{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AMiracle": {
    "Echo": {
      "AdminToken": "",
      "RateLimit": { "IngestionPerMinute": 30, "AdminPerMinute": 600 },
      "MaxAudioBytes": 25000000,
      "MaxScreenshotBytes": 5000000,
      "BlobUploadWindowSeconds": 300,
      "RetentionSweepIntervalMinutes": 60,
      "MaxFeedbackTextChars": 10000,
      "Database": {
        "Provider": "sqlite",
        "ConnectionString": "Data Source=echo.db"
      },
      "BlobStore": {
        "RootPath": "./echo-blobs"
      },
      "Analysis": {
        "Enabled": false,
        "PollIntervalSeconds": 30,
        "BatchSize": 5,
        "PerFeedbackTimeoutSeconds": 90,
        "OpenAI": {
          "ApiKey": "",
          "BaseUrl": "https://api.openai.com/v1",
          "TranscriptionModel": "whisper-1",
          "ChatModel": "gpt-4o-mini",
          "Version": 1
        }
      }
    }
  }
}
