{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AMiracle": {
    "Echo": {
      "AdminToken": "",
      "RateLimit": { "IngestionPerMinute": 30, "AdminPerMinute": 600 },
      "MaxAudioBytes": 25000000,
      "MaxScreenshotBytes": 5000000,
      "BlobUploadWindowSeconds": 300,
      "RetentionSweepIntervalMinutes": 60,
      "MaxFeedbackTextChars": 10000,
      "Database": {
        "Provider": "sqlite",
        "ConnectionString": "Data Source=echo.db"
      },
      "BlobStore": {
        "RootPath": "./echo-blobs"
      }
    }
  }
}
